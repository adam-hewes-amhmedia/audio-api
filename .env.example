# Core
LOG_LEVEL=info
SERVICE_VERSION=dev

# Postgres
DATABASE_URL=postgres://audio:audio@postgres:5432/audio

# NATS
NATS_URL=nats://nats:4222

# Object storage
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_BUCKET=audio-api
OBJECT_STORE_ACCESS_KEY=audioadmin
OBJECT_STORE_SECRET_KEY=audioadminpw
OBJECT_STORE_REGION=us-east-1

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=unset

# API gateway
API_PORT=8080
SYNC_TIMEOUT_MS=60000
JOB_SIZE_LIMIT_MB=10000
# AES-256-GCM key (base64 of 32 bytes) used by the gateway to seal stream
# source.headers and the srt source.passphrase at rest. Generate: `openssl rand -base64 32`.
# The supervisor and pod never read this; they get both from the NATS message.
STREAM_HEADERS_KEY=
# Max concurrent (non-terminal) streams per tenant. 0/unset = unlimited.
STREAM_MAX_CONCURRENT_PER_TENANT=2
# Hosts clients use to reach a pod's SRT endpoints. Two separate addresses on
# purpose: caption TS goes out, srt listener media comes in.
SRT_PUBLIC_HOST=localhost
INGEST_PUBLIC_HOST=localhost
# Dev only. Allows an srt listener with no passphrase, i.e. an unauthenticated
# inbound port. Mirrors STREAM_ALLOW_HTTP; do not set this in production.
# STREAM_ALLOW_UNAUTH_INGEST=1
# Pod tuning (deployment defaults). The admin settings table (ops console)
# overrides these per stream at spawn time; NULL there means "use the value
# here". They live in .env rather than the supervisor's compose block so the
# gateway (a different container) can read them and report each setting's default
# and source.
# Max stream length in seconds. 0 = unlimited (holds a GPU until the stream is
# otherwise ended).
POD_MAX_DURATION_S=30
# Silence before an idle pod gives up.
POD_IDLE_TIMEOUT_S=30
# How long a dropped srt source has to reconnect before the stream ends.
# Encoders drop routinely, so this is the difference between a blip and a dead
# broadcast. A waiting stream still holds its pod and port. 0 disables.
POD_RECONNECT_WINDOW_S=60
# Whisper model: tiny|base|small|medium|large-v3. Bump to medium on a GPU host.
POD_MODEL_SIZE=small

# Worker concurrency
WORKER_CONCURRENCY=2

# Admin API (ops console)
# Off unless explicitly set to 1. The /v1/admin/* surface is cross-tenant by
# design: it can read and kill any tenant's streams and issue tokens for any
# tenant. A route that is never registered cannot leak anything, so leave this
# unset anywhere that does not need it.
# Admin tokens are separate from api_tokens and are bootstrapped with
# `make seed-admin`. There is no env-var fallback on purpose: a shared secret
# here would be unrevocable and unattributable.
ADMIN_API_ENABLED=0
