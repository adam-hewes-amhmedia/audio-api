{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["audio-api", "streams"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Audio API - Live Streams",
  "uid": "audio-api-live-streams",
  "version": 1,
  "weekStart": "",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Stream sessions (last 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(traces_spanmetrics_calls_total{span_name=\"stream.pod.session\"}[1h]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Finalised cues / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "fieldConfig": { "defaults": { "unit": "cpm" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{span_name=\"stream.audio_to_cue\"}[5m])) * 60", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Audio-to-cue latency p95 (ms) - headline KPI; alert > 8000 for 1m",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 8000 }
          ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{span_name=\"stream.audio_to_cue\"}[5m])))",
          "refId": "A", "legendFormat": "p95 audio-to-cue" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Whisper inference duration p95 (ms) by model size",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "id": 4,
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{span_name=\"stream.inference\"}[5m])))",
          "refId": "A", "legendFormat": "p95 inference" }
      ]
    }
  ]
}
