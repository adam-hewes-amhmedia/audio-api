{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "events/file-ready.json",
  "type": "object",
  "required": ["object_key", "size_bytes", "sha256"],
  "properties": {
    "object_key": { "type": "string" },
    "size_bytes": { "type": "integer", "minimum": 0 },
    "sha256":     { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
