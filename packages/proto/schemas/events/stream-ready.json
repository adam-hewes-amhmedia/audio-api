{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "events/stream-ready.json",
  "title": "StreamReady",
  "type": "object",
  "required": ["stream_id","pod_id","ingest_host","ingest_port","ws_port"],
  "additionalProperties": false,
  "properties": {
    "stream_id": { "type": "string" },
    "pod_id":    { "type": "string" },
    "ingest_host": { "type": "string" },
    "ingest_port": { "type": "integer", "minimum": 1024, "maximum": 65535 },
    "ws_port":     { "type": "integer", "minimum": 1024, "maximum": 65535 }
  }
}
